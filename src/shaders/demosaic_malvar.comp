#version 450

// Malvar-He-Cutler (2004) "High-Quality Linear Interpolation for
// Demosaicing of Bayer-Patterned Color Images". A 5x5 linear filter:
// the bilinear estimate plus a gradient correction drawn from the
// known channel. Sharply better edges than the 3x3 mean at modest
// cost. Same Bayer / black-level / EXIF-flip boilerplate as
// demosaic.comp — see that file for the flip-code notes.

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(set = 0, binding = 0, r16)     uniform readonly  image2D in_image;
layout(set = 0, binding = 1, rgba16f) uniform writeonly image2D out_image;

layout(push_constant) uniform PushConstants {
    uvec4 channel_map;        // [c00, c01, c10, c11]
    vec4  black_level;        // R, G, B, G2
    vec4  white_minus_black;
    uvec4 sensor_size_flip;   // .xy = sensor (W, H), .z = flip code
} pc;

uint channel_at(ivec2 p)
{
    return pc.channel_map[(p.y & 1) * 2 + (p.x & 1)];
}

// Black-level-normalized Bayer sample at a sensor coordinate.
float bayer(ivec2 p, ivec2 size)
{
    p = clamp(p, ivec2(0), size - 1);
    uint  ch  = channel_at(p);
    float raw = imageLoad(in_image, p).r * 65535.0;
    return (raw - pc.black_level[ch]) / max(pc.white_minus_black[ch], 1.0);
}

ivec2 sensor_coord_of(ivec2 out_coord, ivec2 sensor_size, uint flip)
{
    if (flip == 3u) {
        return sensor_size - ivec2(1) - out_coord;
    } else if (flip == 5u) {
        return ivec2(sensor_size.x - 1 - out_coord.y, out_coord.x);
    } else if (flip == 6u) {
        return ivec2(out_coord.y, sensor_size.y - 1 - out_coord.x);
    }
    return out_coord;
}

// M is the 5x5 normalized window, M[row][col], center M[2][2].
// Each mask sums to 8.

// Green at a red or blue pixel.
float malvar_g_at_rb(float M[5][5])
{
    float v = 4.0 * M[2][2]
            + 2.0 * (M[1][2] + M[3][2] + M[2][1] + M[2][3])
            - 1.0 * (M[0][2] + M[4][2] + M[2][0] + M[2][4]);
    return v / 8.0;
}

// Estimate at a green pixel, with the target channel's known
// neighbors on the *horizontal* axis.
float malvar_at_g_horiz(float M[5][5])
{
    float v = 5.0 * M[2][2]
            + 4.0 * (M[2][1] + M[2][3])
            + 0.5 * (M[0][2] + M[4][2])
            - 1.0 * (M[1][1] + M[1][3] + M[3][1] + M[3][3])
            - 1.0 * (M[2][0] + M[2][4]);
    return v / 8.0;
}

// Estimate at a green pixel, target channel's neighbors *vertical*.
float malvar_at_g_vert(float M[5][5])
{
    float v = 5.0 * M[2][2]
            + 4.0 * (M[1][2] + M[3][2])
            + 0.5 * (M[2][0] + M[2][4])
            - 1.0 * (M[1][1] + M[1][3] + M[3][1] + M[3][3])
            - 1.0 * (M[0][2] + M[4][2]);
    return v / 8.0;
}

// Red at a blue pixel / blue at a red pixel (diagonal neighbors).
float malvar_diag(float M[5][5])
{
    float v = 6.0 * M[2][2]
            + 2.0 * (M[1][1] + M[1][3] + M[3][1] + M[3][3])
            - 1.5 * (M[0][2] + M[4][2] + M[2][0] + M[2][4]);
    return v / 8.0;
}

void main()
{
    ivec2 out_coord = ivec2(gl_GlobalInvocationID.xy);
    ivec2 out_size  = imageSize(out_image);
    if (out_coord.x >= out_size.x || out_coord.y >= out_size.y) return;

    ivec2 sensor_size = ivec2(pc.sensor_size_flip.xy);
    uint  flip        = pc.sensor_size_flip.z;
    ivec2 center      = sensor_coord_of(out_coord, sensor_size, flip);

    float M[5][5];
    for (int dy = -2; dy <= 2; dy++) {
        for (int dx = -2; dx <= 2; dx++) {
            M[dy + 2][dx + 2] = bayer(center + ivec2(dx, dy), sensor_size);
        }
    }

    float c      = M[2][2];
    uint  ch     = channel_at(center);
    uint  out_ch = (ch == 3u) ? 1u : ch;

    vec3 rgb;
    if (out_ch == 0u) {            // red pixel
        rgb.r = c;
        rgb.g = malvar_g_at_rb(M);
        rgb.b = malvar_diag(M);
    } else if (out_ch == 2u) {     // blue pixel
        rgb.b = c;
        rgb.g = malvar_g_at_rb(M);
        rgb.r = malvar_diag(M);
    } else {                       // green pixel
        rgb.g = c;
        // Horizontal neighbour's channel decides which axis carries R.
        uint h = channel_at(center + ivec2(1, 0));
        if (h == 0u) {             // green in a red row
            rgb.r = malvar_at_g_horiz(M);
            rgb.b = malvar_at_g_vert(M);
        } else {                   // green in a blue row
            rgb.b = malvar_at_g_horiz(M);
            rgb.r = malvar_at_g_vert(M);
        }
    }

    imageStore(out_image, out_coord, vec4(max(rgb, vec3(0.0)), 1.0));
}
